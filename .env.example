SEOUL_API_KEY=
KAKAO_REST_API_KEY=
VITE_KAKAO_JS_KEY=
INSIGHT_CACHE_ADMIN_TOKEN=

# Server-side only. Used by Netlify Functions and local seed scripts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KOSIS_API_KEY=

# Local documentation automation only. Do not expose this in client-side Vite env.
NOTION_TOKEN=
NOTION_PROJECT_PAGE_ID=

# Server-side LLM harness. Keep provider keys out of Vite client env.
# mock keeps the UI free while developing. Use openai, gemini, or anthropic for direct provider billing.
# netlify-ai-gateway is available only when you intentionally want Netlify AI Gateway billing.
LLM_PROVIDER=mock
LLM_MODEL_PROVIDER=openai
LLM_COST_PROFILE=balanced
LLM_ESCALATION_ENABLED=true

# Direct provider keys. These names avoid collisions with Netlify AI Gateway's auto-injected env vars.
DIRECT_OPENAI_API_KEY=
DIRECT_OPENAI_BASE_URL=
DIRECT_GEMINI_API_KEY=
DIRECT_GOOGLE_GEMINI_BASE_URL=
DIRECT_ANTHROPIC_API_KEY=
DIRECT_ANTHROPIC_BASE_URL=

# Model routing
OPENAI_MODEL_SHORT=gpt-5.4-mini
OPENAI_MODEL_INSIGHT=gpt-5.4-mini
OPENAI_MODEL_REPORT=gpt-5.4
OPENAI_MODEL_PREMIUM=gpt-5.5

GEMINI_MODEL_SHORT=gemini-2.5-flash-lite
GEMINI_MODEL_INSIGHT=gemini-3.1-flash-lite
GEMINI_MODEL_REPORT=gemini-3.1-pro-preview

ANTHROPIC_MODEL_SHORT=claude-haiku-4-5
ANTHROPIC_MODEL_REPORT=claude-sonnet-4-6

# Optional direct API candidate. Not currently routed through Netlify AI Gateway.
MISTRAL_API_KEY=
MISTRAL_MODEL_SHORT=mistral-small-latest

# Batch cache refresh scripts / GitHub Actions
INSIGHT_API_BASE_URL=http://localhost:3000/api/insight-api
LLM_HARNESS_BASE_URL=http://localhost:3000/api/llm-harness
LLM_REFRESH_PROVIDER=direct-openai
LLM_REFRESH_CONCURRENCY=2
LLM_REFRESH_SLEEP_MS=750
LLM_REFRESH_LIMIT=0
LLM_SOURCE_FORCE_REFRESH=0
