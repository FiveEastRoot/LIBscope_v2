{
  "name": "libscope-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "dev:vite": "vite",
    "build:function-data": "node scripts/build-static-function-data.cjs",
    "build": "vite build",
    "refresh:insight-cache": "node scripts/refresh-insight-cache.cjs",
    "refresh:insight-cache:district": "cross-env INSIGHT_REFRESH_SCOPE=district npm run refresh:insight-cache",
    "refresh:insight-cache:library": "cross-env INSIGHT_REFRESH_SCOPE=library npm run refresh:insight-cache",
    "refresh:llm-cache": "node scripts/refresh-llm-cache.cjs",
    "auto-improve:feedback:dry-run": "node scripts/run-auto-improvement-feedback.cjs --dry-run",
    "auto-improve:feedback:single": "cross-env AUTO_IMPROVE_ARTIFACT_LIMIT=1 node scripts/run-auto-improvement-feedback.cjs --save",
    "auto-improve:feedback:sample": "node scripts/run-auto-improvement-feedback.cjs --save",
    "auto-improve:prompt-draft:dry-run": "node scripts/run-prompt-improvement-draft.cjs --dry-run",
    "auto-improve:prompt-draft:sample": "node scripts/run-prompt-improvement-draft.cjs --save",
    "auto-improve:prompt-ab": "node scripts/run-prompt-ab-test.cjs",
    "auto-improve:prompt-activate": "node scripts/activate-prompt-version.cjs",
    "seed:supabase": "node scripts/seed-supabase-metrics.cjs",
    "notion:create": "node scripts/notion-create-page.cjs",
    "verify:deploy-visuals": "node scripts/verify-deploy-visuals.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "netlify-cli": "^26.1.0",
    "postcss": "^8.5.15",
    "supabase": "^2.106.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
